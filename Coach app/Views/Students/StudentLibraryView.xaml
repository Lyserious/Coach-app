<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Coach_app.ViewModels.Students"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:shared="clr-namespace:Coach_app.Views.Shared"
             x:Class="Coach_app.Views.Students.StudentLibraryView"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource BrandDarkBlue}"
             Shell.NavBarIsVisible="False">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadDataCommand}" />
    </ContentPage.Behaviors>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnPlatform WinUI='250', MacCatalyst='250', Default='0'}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <shared:SidebarView Grid.Column="0" IsVisible="{OnPlatform WinUI='True', MacCatalyst='True', Default='False'}" />

        <Grid Grid.Column="1" RowDefinitions="Auto, Auto, Auto, *, Auto" Padding="20" RowSpacing="15">

            <Grid Grid.Row="0" ColumnDefinitions="Auto, *" VerticalOptions="Center" Margin="0,0,0,10">

                <Border Grid.Column="0"
                        Stroke="{StaticResource BrandCoral}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        HeightRequest="40"
                        WidthRequest="40"
                        Margin="0,0,15,0"
                        BackgroundColor="{StaticResource BrandNavyBlue}"
                        IsVisible="{OnPlatform Android=True, iOS=True, WinUI=False, MacCatalyst=False}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type Shell}}, Path=FlyoutIsPresented}" CommandParameter="True" />
                    </Border.GestureRecognizers>
                    <Label Text="☰" TextColor="{StaticResource BrandCoral}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <Label Grid.Column="1"
                       Text="Annuaire Élèves" 
                       FontSize="28" 
                       FontFamily="OpenSansSemibold" 
                       TextColor="{StaticResource NeutralWhite}"
                       VerticalOptions="Center"/>
            </Grid>

            <SearchBar Grid.Row="1"
                       Placeholder="Rechercher (Nom, Prénom, Surnom)..."
                       Text="{Binding SearchText}"
                       BackgroundColor="{StaticResource BrandNavyBlue}"
                       TextColor="{StaticResource NeutralWhite}"
                       PlaceholderColor="{StaticResource NeutralLightGray}"
                       CancelButtonColor="{StaticResource BrandCoral}"/>

            <Grid Grid.Row="2" ColumnDefinitions="*, Auto">
                <ScrollView Grid.Column="0" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="10" Padding="0,5">

                        <Button Text="Nom" Command="{Binding SortByCommand}" CommandParameter="LastName" 
                                FontSize="13" FontFamily="OpenSansSemibold" Padding="15,0" HeightRequest="35" CornerRadius="18" 
                                BackgroundColor="{StaticResource BrandNavyBlue}" TextColor="{StaticResource NeutralWhite}"/>

                        <Button Text="Prénom" Command="{Binding SortByCommand}" CommandParameter="FirstName" 
                                FontSize="13" FontFamily="OpenSansSemibold" Padding="15,0" HeightRequest="35" CornerRadius="18" 
                                BackgroundColor="{StaticResource BrandNavyBlue}" TextColor="{StaticResource NeutralWhite}"/>

                        <Button Text="Âge" Command="{Binding SortByCommand}" CommandParameter="Age" 
                                FontSize="13" FontFamily="OpenSansSemibold" Padding="15,0" HeightRequest="35" CornerRadius="18" 
                                BackgroundColor="{StaticResource BrandNavyBlue}" TextColor="{StaticResource NeutralWhite}"/>

                        <Button Text="Niveau" Command="{Binding SortByCommand}" CommandParameter="Level" 
                                FontSize="13" FontFamily="OpenSansSemibold" Padding="15,0" HeightRequest="35" CornerRadius="18" 
                                BackgroundColor="{StaticResource BrandNavyBlue}" TextColor="{StaticResource NeutralWhite}"/>

                        <Button Text="Surnom" Command="{Binding SortByCommand}" CommandParameter="Nickname" 
                                FontSize="13" FontFamily="OpenSansSemibold" Padding="15,0" HeightRequest="35" CornerRadius="18" 
                                BackgroundColor="{StaticResource BrandNavyBlue}" TextColor="{StaticResource NeutralWhite}"/>
                    </HorizontalStackLayout>
                </ScrollView>

                <Button Grid.Column="1" 
                        Text="{Binding SortDirectionIcon}" 
                        Command="{Binding ToggleSortDirectionCommand}"
                        BackgroundColor="Transparent" TextColor="{StaticResource BrandCoral}" FontSize="20" FontFamily="OpenSansSemibold"
                        Padding="10,0,0,0"/>
            </Grid>

            <CollectionView Grid.Row="3" 
                            ItemsSource="{Binding Students}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedStudent}">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="🕵️" FontSize="36" HorizontalOptions="Center" Opacity="0.8"/>
                        <Label Text="Aucun élève trouvé." TextColor="{StaticResource NeutralLightGray}" FontFamily="OpenSansSemibold" FontSize="15"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Padding="15" StrokeShape="RoundRectangle 15" 
                                BackgroundColor="{StaticResource BrandNavyBlue}" StrokeThickness="0">

                            <Grid ColumnDefinitions="55, *, Auto">

                                <Border Grid.Column="0" Stroke="{StaticResource BrandCoral}" StrokeThickness="1" StrokeShape="RoundRectangle 25"
                                        HeightRequest="50" WidthRequest="50" HorizontalOptions="Center" VerticalOptions="Center" IsClippedToBounds="True">
                                    <Image Source="{Binding ProfilePhotoPath, Converter={StaticResource StringNullToImageConverter}}" 
                                           Aspect="AspectFill" HeightRequest="50" WidthRequest="50"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0,0,0" Spacing="2">
                                    <Label Text="{Binding DisplayName}" FontFamily="OpenSansSemibold" FontSize="16" TextColor="{StaticResource NeutralWhite}"/>
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="{Binding Age, StringFormat='{0} ans'}" FontSize="13" TextColor="{StaticResource NeutralLightGray}"/>
                                        <Label Text="{Binding MaxLevel, StringFormat='• Niveau : {0}'}" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{StaticResource BrandCoral}"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <Label Grid.Column="2" Text="›" FontSize="26" TextColor="{StaticResource NeutralGray}" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Grid.Row="4" Text="+ NOUVEL ÉLÈVE" 
                    Command="{Binding AddStudentCommand}"
                    BackgroundColor="{StaticResource BrandCoral}" 
                    TextColor="{StaticResource NeutralWhite}" 
                    FontFamily="OpenSansSemibold"
                    FontSize="14"
                    CornerRadius="25" 
                    HeightRequest="55"
                    Margin="0,10,0,0"/>
        </Grid>
    </Grid>
</ContentPage>