<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Coach_app.ViewModels.Groups"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit" 
             x:Class="Coach_app.Views.Groups.GroupDashboardView"
             Title="{Binding GroupName}"
             BackgroundColor="{StaticResource BrandDarkBlue}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadDataCommand}" />
    </ContentPage.Behaviors>

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="20" BackgroundColor="{StaticResource BrandNavyBlue}">

            <Border Grid.Column="0" HeightRequest="60" WidthRequest="60" StrokeShape="RoundRectangle 30" 
                    Stroke="{StaticResource BrandCoral}" StrokeThickness="2" BackgroundColor="{StaticResource BrandDarkBlue}" 
                    Margin="0,0,15,0" IsVisible="{Binding PhotoPath, Converter={toolkit:IsStringNotNullOrEmptyConverter}}">
                <Image Source="{Binding PhotoPath}" Aspect="AspectFill"/>
            </Border>

            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                <Label Text="{Binding GroupName}" TextColor="{StaticResource NeutralWhite}" FontSize="24" FontFamily="OpenSansSemibold" LineBreakMode="TailTruncation"/>
                <Label Text="Tableau de bord" TextColor="{StaticResource BrandCoral}" FontFamily="OpenSansSemibold" FontSize="13"/>
            </VerticalStackLayout>

            <Button Grid.Column="2" Text="✎ PARAMÈTRES" Command="{Binding EditGroupCommand}"
                    BackgroundColor="Transparent" TextColor="{StaticResource NeutralLightGray}"
                    BorderColor="{StaticResource NeutralLightGray}" BorderWidth="1"
                    FontSize="11" FontFamily="OpenSansSemibold" HeightRequest="35" CornerRadius="8" VerticalOptions="Center"/>
        </Grid>

        <ScrollView Grid.Row="1" Padding="20">
            <VerticalStackLayout Spacing="25">

                <Border StrokeShape="RoundRectangle 15" BackgroundColor="{StaticResource BrandNavyBlue}" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="📅 CALENDRIER &amp; SÉANCES" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource NeutralWhite}" CharacterSpacing="1"/>

                        <Border BackgroundColor="{StaticResource BrandDarkBlue}" StrokeShape="RoundRectangle 10" Padding="15" StrokeThickness="0">
                            <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto">
                                <Label Grid.RowSpan="2" Grid.Column="0" Text="PROCHAINE" FontSize="11" FontFamily="OpenSansSemibold" TextColor="{StaticResource BrandCoral}" VerticalOptions="Center" Margin="0,0,15,0" Rotation="-90" />
                                <Label Grid.Row="0" Grid.Column="1" Text="Lundi 14 Octobre" FontFamily="OpenSansSemibold" TextColor="{StaticResource NeutralWhite}" FontSize="15"/>
                                <Label Grid.Row="1" Grid.Column="1" Text="18:00 - 20:00 (Endurance)" TextColor="{StaticResource NeutralLightGray}" FontSize="13" Margin="0,2,0,0"/>
                            </Grid>
                        </Border>

                        <Button Text="Voir tout le calendrier" 
                                Command="{Binding GoToCalendarCommand}"
                                BackgroundColor="Transparent" TextColor="{StaticResource BrandCoral}" 
                                BorderColor="{StaticResource BrandCoral}" BorderWidth="1"
                                FontFamily="OpenSansSemibold" HeightRequest="45" CornerRadius="10" Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 15" BackgroundColor="{StaticResource BrandNavyBlue}" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10" VerticalOptions="Center">
                            <Label Grid.Column="0" Text="👥 ÉLÈVES" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{StaticResource NeutralWhite}" CharacterSpacing="1" VerticalOptions="Center"/>

                            <Button Grid.Column="1" Text="🔍 Importer" Command="{Binding ImportStudentCommand}" 
                                    FontSize="11" FontFamily="OpenSansSemibold" HeightRequest="35" Padding="15,0" CornerRadius="8"
                                    BackgroundColor="{StaticResource BrandDarkBlue}" TextColor="{StaticResource NeutralLightGray}"/>

                            <Button Grid.Column="2" Text="+ Nouveau" Command="{Binding AddStudentCommand}" 
                                    FontSize="11" FontFamily="OpenSansSemibold" HeightRequest="35" Padding="15,0" CornerRadius="8"
                                    BackgroundColor="{StaticResource BrandCoral}" TextColor="{StaticResource NeutralWhite}"/>
                        </Grid>

                        <CollectionView ItemsSource="{Binding Students}" HeightRequest="250">
                            <CollectionView.EmptyView>
                                <Label Text="Aucun élève. Ajoutez-en un !" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{StaticResource NeutralLightGray}" Margin="0,30,0,0"/>
                            </CollectionView.EmptyView>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="{StaticResource BrandDarkBlue}" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="10" Margin="0,0,0,10">

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GroupDashboardViewModel}}, Path=GoToStudentProfileCommand}" CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="45, *, Auto">
                                            <Border Grid.Column="0" HeightRequest="40" WidthRequest="40" StrokeShape="RoundRectangle 20" StrokeThickness="0" HorizontalOptions="Start" VerticalOptions="Center">
                                                <Image Source="{Binding ProfilePhotoPath, Converter={StaticResource StringNullToImageConverter}}" Aspect="AspectFill"/>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0">
                                                <Label Text="{Binding DisplayName}" FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource NeutralWhite}"/>
                                                <Label Text="{Binding MaxLevel, StringFormat='Niveau : {0}'}" TextColor="{StaticResource NeutralLightGray}" FontSize="12"/>
                                            </VerticalStackLayout>

                                            <Label Grid.Column="2" Text="›" FontSize="24" TextColor="{StaticResource NeutralGray}" VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Button Text="📷 GALERIE PHOTOS DU GROUPE" 
                        Command="{Binding GoToGalleryCommand}"
                        BackgroundColor="{StaticResource BrandCoral}" TextColor="{StaticResource NeutralWhite}" 
                        FontFamily="OpenSansSemibold" HeightRequest="55" CornerRadius="12"
                        Margin="0,10,0,40"
                        Shadow="{Shadow Brush=Black, Offset='0,4', Opacity=0.2}"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>