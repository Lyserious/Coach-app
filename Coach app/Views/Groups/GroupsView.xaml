<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Coach_app.ViewModels.Groups"
             xmlns:models="clr-namespace:Coach_app.Models"
             xmlns:shared="clr-namespace:Coach_app.Views.Shared"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit" 
             x:Class="Coach_app.Views.Groups.GroupsView"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource BrandDarkBlue}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadGroupsCommand}" />
    </ContentPage.Behaviors>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnPlatform WinUI='250', MacCatalyst='250', Default='0'}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <shared:SidebarView Grid.Column="0" IsVisible="{OnPlatform WinUI='True', MacCatalyst='True', Default='False'}" />

        <Grid Grid.Column="1" RowDefinitions="Auto, Auto, *" Padding="20">

            <Grid Grid.Row="0" ColumnDefinitions="Auto, *" VerticalOptions="Center" Margin="0,0,0,10">

                <Border Grid.Column="0"
                        Stroke="{StaticResource BrandCoral}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        HeightRequest="40"
                        WidthRequest="40"
                        Margin="0,0,15,0"
                        BackgroundColor="{StaticResource BrandNavyBlue}"
                        IsVisible="{OnPlatform Android=True, iOS=True, WinUI=False, MacCatalyst=False}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type Shell}}, Path=FlyoutIsPresented}" CommandParameter="True" />
                    </Border.GestureRecognizers>
                    <Label Text="☰" TextColor="{StaticResource BrandCoral}" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <Label Grid.Column="1"
                       Text="{Binding Title}" 
                       FontSize="28" 
                       FontFamily="OpenSansSemibold" 
                       TextColor="{StaticResource NeutralWhite}"
                       VerticalOptions="Center"/>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,20" VerticalOptions="End">
                <Label Grid.Column="0" 
                       Text="Groupes récurrents &amp; Stages" 
                       FontSize="15" 
                       TextColor="{StaticResource NeutralLightGray}" 
                       VerticalOptions="Center"/>

                <Button Grid.Column="1" 
                        Text="+ CRÉER" 
                        Command="{Binding AddGroupCommand}"
                        BackgroundColor="{StaticResource BrandCoral}" 
                        TextColor="{StaticResource NeutralWhite}" 
                        FontFamily="OpenSansSemibold"
                        HeightRequest="40" 
                        Padding="20,0"
                        CornerRadius="20"/>
            </Grid>

            <CollectionView Grid.Row="2" 
                            ItemsSource="{Binding Groups}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedGroup}">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="{OnIdiom Phone=1, Tablet=2, Desktop=3}" VerticalItemSpacing="15" HorizontalItemSpacing="15"/>
                </CollectionView.ItemsLayout>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Margin="0,40,0,0">
                        <Label Text="📭" FontSize="40" HorizontalOptions="Center" Opacity="0.8"/>
                        <Label Text="Aucun groupe trouvé" TextColor="{StaticResource NeutralLightGray}" FontFamily="OpenSansSemibold" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 15" BackgroundColor="{StaticResource BrandNavyBlue}" StrokeThickness="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GroupLibraryViewModel}}, Path=GoToGroupDetailCommand}" CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid RowDefinitions="140, Auto">
                                <Image Grid.Row="0" 
                                       Source="{Binding PhotoPath, Converter={StaticResource StringNullToImageConverter}}" 
                                       Aspect="AspectFill" 
                                       BackgroundColor="{StaticResource BrandDarkBlue}"/>

                                <BoxView Grid.Row="0" Color="Black" Opacity="0.2"/>

                                <Border Grid.Row="0" 
                                        BackgroundColor="{StaticResource BrandCoral}" 
                                        HorizontalOptions="End" 
                                        VerticalOptions="Start" 
                                        Margin="10" 
                                        Padding="10,5" 
                                        StrokeShape="RoundRectangle 10" 
                                        StrokeThickness="0">
                                    <Label Text="{Binding Type}" FontSize="11" FontFamily="OpenSansSemibold" TextColor="{StaticResource NeutralWhite}"/>
                                </Border>

                                <VerticalStackLayout Grid.Row="1" Padding="15" Spacing="4">
                                    <Label Text="{Binding Name}" FontSize="16" FontFamily="OpenSansSemibold" TextColor="{StaticResource NeutralWhite}"/>
                                    <Label Text="{Binding Schedule}" FontSize="13" TextColor="{StaticResource NeutralLightGray}"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Grid>
</ContentPage>