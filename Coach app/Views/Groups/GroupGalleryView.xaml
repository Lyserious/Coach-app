<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Coach_app.ViewModels.Groups"
             x:Class="Coach_app.Views.Groups.GroupGalleryView"
             Title="Media Wall"
             BackgroundColor="{StaticResource BrandDarkBlue}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" Padding="20">
            <VerticalStackLayout VerticalOptions="Center">
                <Label Text="Souvenirs &amp; Analyse" FontSize="12" TextColor="{StaticResource BrandCoral}" TextTransform="Uppercase" CharacterSpacing="1" FontFamily="OpenSansSemibold"/>
                <Label Text="Galerie du Groupe" FontSize="24" FontFamily="OpenSansSemibold" TextColor="{StaticResource NeutralWhite}"/>
            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Row="1">
            <ScrollView>
                <FlexLayout BindableLayout.ItemsSource="{Binding Photos}" 
                            Wrap="Wrap" 
                            JustifyContent="Start"
                            AlignItems="Start"
                            AlignContent="Start"
                            Padding="15,0,15,80">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 10" 
                                    Stroke="{StaticResource BrandDarkBlue}" 
                                    StrokeThickness="2" 
                                    BackgroundColor="{StaticResource BrandNavyBlue}" 
                                    Margin="0,0,10,10"
                                    HorizontalOptions="Start"
                                    VerticalOptions="Start">
                                <Grid>
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GroupGalleryViewModel}}, Path=OpenPhotoCommand}" CommandParameter="{Binding .}"/>
                                    </Grid.GestureRecognizers>

                                    <Image Source="{Binding FilePath}" 
                                           Aspect="AspectFit" 
                                           HeightRequest="150"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>

                                    <Border VerticalOptions="End" HorizontalOptions="Start" Margin="5" BackgroundColor="#AA000000" StrokeThickness="0" StrokeShape="RoundRectangle 5" Padding="5,2">
                                        <Label Text="{Binding DateTaken, StringFormat='{0:dd MMM}'}" TextColor="{StaticResource NeutralWhite}" FontSize="10" FontFamily="OpenSansSemibold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>
            </ScrollView>

            <Label Text="C'est vide ici ! Importe des photos." 
                   TextColor="{StaticResource NeutralLightGray}" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" 
                   IsVisible="False">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding Photos.Count}" Value="0">
                        <Setter Property="IsVisible" Value="True" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>

            <Button Text="+" 
                    Command="{Binding ImportPhotoCommand}" 
                    FontSize="32" 
                    TextColor="{StaticResource NeutralWhite}" 
                    BackgroundColor="{StaticResource BrandCoral}" 
                    CornerRadius="30" 
                    HeightRequest="60" 
                    WidthRequest="60" 
                    HorizontalOptions="End" 
                    VerticalOptions="End" 
                    Margin="15"
                    Shadow="{Shadow Brush=Black, Offset='0,4', Opacity=0.4}"/>
        </Grid>
    </Grid>
</ContentPage>