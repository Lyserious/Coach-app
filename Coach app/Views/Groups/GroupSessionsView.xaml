<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Coach_app.ViewModels.Groups"
             x:Class="Coach_app.Views.Groups.GroupSessionsView"
             Title="Gestion Calendrier"
             BackgroundColor="{StaticResource BrandDarkBlue}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *" HorizontalOptions="Fill" VerticalOptions="Fill">

        <VerticalStackLayout Grid.Row="0">
            <Label Text="Calendrier" FontSize="24" FontFamily="OpenSansSemibold" TextColor="{StaticResource NeutralWhite}" Margin="20"/>

            <Border BackgroundColor="{StaticResource BrandNavyBlue}" Padding="20" Margin="15,0,15,15" StrokeShape="RoundRectangle 15" StrokeThickness="0">
                <VerticalStackLayout Spacing="15">
                    <Label Text="PLANIFIER UNE SÉANCE" FontFamily="OpenSansSemibold" TextColor="{StaticResource BrandCoral}" FontSize="14" CharacterSpacing="1"/>

                    <VerticalStackLayout Spacing="5">
                        <Label Text="Date de la séance" FontSize="12" TextColor="{StaticResource NeutralLightGray}"/>
                        <Border Stroke="{StaticResource BrandDarkBlue}" StrokeThickness="1" StrokeShape="RoundRectangle 8" BackgroundColor="Transparent" Padding="5,0">
                            <DatePicker Date="{Binding NewDate, Mode=TwoWay}" Format="dddd dd MMMM yyyy" TextColor="{StaticResource NeutralWhite}" FontSize="14" HorizontalOptions="Fill"/>
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*, Auto, *">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Début" FontSize="12" TextColor="{StaticResource NeutralLightGray}" HorizontalOptions="Center"/>
                            <TimePicker Time="{Binding NewStartTime}" TextColor="{StaticResource NeutralWhite}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <Label Text="à" Grid.Column="1" VerticalOptions="Center" TextColor="{StaticResource NeutralLightGray}" Margin="10,0"/>
                        <VerticalStackLayout Grid.Column="2" Spacing="5">
                            <Label Text="Fin" FontSize="12" TextColor="{StaticResource NeutralLightGray}" HorizontalOptions="Center"/>
                            <TimePicker Time="{Binding NewEndTime}" TextColor="{StaticResource NeutralWhite}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Button Text="Ajouter au calendrier" Command="{Binding AddSessionCommand}" BackgroundColor="{StaticResource BrandCoral}" TextColor="{StaticResource NeutralWhite}" CornerRadius="20" HeightRequest="45" FontFamily="OpenSansSemibold" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <Grid Grid.Row="1" Margin="15,0">
            <CollectionView ItemsSource="{Binding Sessions}" HorizontalOptions="Fill" VerticalOptions="Fill">

                <CollectionView.EmptyView>
                    <Label Text="Aucune séance prévue." HorizontalOptions="Center" VerticalOptions="Center" TextColor="{StaticResource NeutralLightGray}" Margin="0,30"/>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" Padding="15" StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource BrandNavyBlue}" StrokeThickness="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GroupSessionsViewModel}}, Path=GoToSessionCommand}" CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Border Grid.Column="0" Stroke="{StaticResource BrandCoral}" StrokeThickness="1" WidthRequest="55" HeightRequest="55" StrokeShape="RoundRectangle 12" BackgroundColor="{StaticResource BrandDarkBlue}" VerticalOptions="Center" Margin="0,0,15,0">
                                    <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                                        <Label Text="{Binding Date, StringFormat='{0:dd}'}" FontSize="18" FontFamily="OpenSansSemibold" HorizontalOptions="Center" TextColor="{StaticResource BrandCoral}"/>
                                        <Label Text="{Binding Date, StringFormat='{0:MMM}'}" FontSize="11" HorizontalOptions="Center" TextColor="{StaticResource BrandCoral}" TextTransform="Uppercase"/>
                                    </VerticalStackLayout>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Date, StringFormat='{0:dddd dd MMMM}'}" FontFamily="OpenSansSemibold" TextColor="{StaticResource NeutralWhite}" FontSize="15" />
                                    <Label Text="{Binding StartTime, StringFormat='{0:hh\\:mm} - ...'}" TextColor="{StaticResource NeutralLightGray}" FontSize="13"/>
                                </VerticalStackLayout>

                                <Button Grid.Column="2" Text="✕" BackgroundColor="Transparent" TextColor="{StaticResource BrandCoral}" FontSize="18" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GroupSessionsViewModel}}, Path=DeleteSessionCommand}" CommandParameter="{Binding .}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

    </Grid>
</ContentPage>