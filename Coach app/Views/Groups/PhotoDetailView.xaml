<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Coach_app.ViewModels.Groups"
             x:Class="Coach_app.Views.Groups.PhotoDetailView"
             Title="Détail Photo"
             BackgroundColor="Black"
             Shell.NavBarIsVisible="False">

    <Grid>
        <Image Source="{Binding ImagePath}" Aspect="AspectFit" HorizontalOptions="Fill" VerticalOptions="Fill" ZIndex="1"/>

        <Button Text="⋮" Command="{Binding ShowOptionsCommand}" FontSize="24" FontFamily="OpenSansSemibold" BackgroundColor="#80000000" TextColor="{StaticResource NeutralWhite}" CornerRadius="25" HeightRequest="50" WidthRequest="50" Padding="0" Margin="0,15,15,0" HorizontalOptions="End" VerticalOptions="Start" ZIndex="2"/>

        <Grid IsVisible="{Binding IsTaggingVisible}" BackgroundColor="#CC000000" VerticalOptions="Fill" HorizontalOptions="Fill" ZIndex="3">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding HideTaggingCommand}"/>
            </Grid.GestureRecognizers>

            <Border VerticalOptions="End" StrokeShape="RoundRectangle 20,20,0,0" BackgroundColor="{StaticResource BrandNavyBlue}" Padding="20,25,20,40" StrokeThickness="0">
                <VerticalStackLayout Spacing="15">

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Qui est sur cette photo ?" FontFamily="OpenSansSemibold" FontSize="16" TextColor="{StaticResource NeutralWhite}" VerticalOptions="Center"/>
                        <Button Text="✕" Command="{Binding HideTaggingCommand}" BackgroundColor="Transparent" TextColor="{StaticResource NeutralLightGray}" Grid.Column="1" FontSize="18" Padding="0"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding Students}" HeightRequest="250" Margin="0,10">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto, *" Padding="5,10">
                                    <CheckBox IsChecked="{Binding IsTagged}" Grid.Column="0" Color="{StaticResource BrandCoral}"/>
                                    <Label Text="{Binding Name}" VerticalOptions="Center" Grid.Column="1" TextColor="{StaticResource NeutralWhite}" FontSize="15" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Text="Enregistrer" Command="{Binding SaveTagsCommand}" BackgroundColor="{StaticResource BrandCoral}" TextColor="{StaticResource NeutralWhite}" CornerRadius="12" HeightRequest="50" FontFamily="OpenSansSemibold"/>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>